@page "{id:int}"
@model AdminPersonal.Pages.Oferentes.EditarModel
@{
    ViewData["Title"] = "Editar Oferente";
}

<h2>Editar Oferente</h2>

@if (ViewData["Error"] != null)
{
    <div class="alert alert-danger">@ViewData["Error"]</div>
}

<form method="post">
    <input type="hidden" name="Oferente.id_oferente" value="@Model.Oferente.id_oferente" />

    <div class="mb-3">
        <label>Tipo de Identificación</label>
        <select asp-for="Oferente.TipoIdentificacion" class="form-control" required>
            <option value="">-- Seleccione --</option>
            <option value="Cédula de identidad">Cédula de identidad</option>
            <option value="DIMEX">DIMEX</option>
            <option value="Pasaporte">Pasaporte</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Identificación</label>
        <input type="text"
               name="Oferente.Identificacion"
               class="form-control"
               maxlength="20"
               value="@Model.Oferente.Identificacion"
               required />
    </div>

    <div class="mb-3">
        <label>Nombre Completo</label>
        <input type="text"
               name="Oferente.NombreCompleto"
               class="form-control"
               maxlength="150"
               value="@Model.Oferente.NombreCompleto"
               required />
    </div>

    <div class="mb-3">
        <label>Fecha de Nacimiento</label>
        <input type="date"
               name="Oferente.FechaNacimiento"
               class="form-control"
               value="@Model.Oferente.FechaNacimiento.ToString("yyyy-MM-dd")"
               required />
    </div>

    <hr />
    <h5>Correos Electrónicos</h5>

    <div id="correos-container">
        @for (int i = 0; i < Model.Correos.Count; i++)
        {
            <div class="input-group mb-2">
                <input type="email"
                       name="Correos[@i]"
                       class="form-control"
                       value="@Model.Correos[i]" />

                <button type="button"
                        class="btn btn-danger btn-sm"
                        onclick="eliminarCampo(this)">
                    ×
                </button>
            </div>
        }
    </div>

    <button type="button"
            class="btn btn-secondary btn-sm mb-3"
            onclick="agregarCorreo()">
        + Agregar correo
    </button>

    <hr />
    <h5>Teléfonos</h5>

    <div id="telefonos-container">
        @for (int i = 0; i < Model.Telefonos.Count; i++)
        {
            <div class="input-group mb-2">
                <input type="text"
                       name="Telefonos[@i]"
                       class="form-control"
                       value="@Model.Telefonos[i]"
                       maxlength="20" />

                <button type="button"
                        class="btn btn-danger btn-sm"
                        onclick="eliminarCampo(this)">
                    ×
                </button>
            </div>
        }
    </div>

    <button type="button"
            class="btn btn-secondary btn-sm mb-3"
            onclick="agregarTelefono()">
        + Agregar teléfono
    </button>

    <hr />
    <h5>Concursos</h5>

    <div class="mb-3">
        @foreach (var c in Model.Concursos)
        {
            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       name="ConcursosSeleccionados"
                       value="@c.id_concurso"
                       id="conc_@c.id_concurso"
                       @(Model.Oferente.ConcursosIds.Contains(c.id_concurso) ? "checked" : "") />

                <label class="form-check-label"
                       for="conc_@c.id_concurso">
                    @c.Nombre (@c.Codigo)
                </label>
            </div>
        }
    </div>

    <br />

    <a asp-page="Index" class="btn btn-secondary">
        Volver
    </a>

    <button type="submit" class="btn btn-primary">
        Guardar
    </button>
</form>

@section Scripts {
    <script>
        let correoIdx = @Model.Correos.Count;
        let telefonoIdx = @Model.Telefonos.Count;

        function agregarCorreo() {
            const div = document.createElement('div');
            div.className = 'input-group mb-2';

            div.innerHTML =
                `<input type="email"
                        name="Correos[${correoIdx}]"
                        class="form-control"
                        placeholder="correo@ejemplo.com" />

                 <button type="button"
                         class="btn btn-danger btn-sm"
                         onclick="eliminarCampo(this)">
                    ×
                 </button>`;

            document.getElementById('correos-container').appendChild(div);
            correoIdx++;
        }

        function agregarTelefono() {
            const div = document.createElement('div');
            div.className = 'input-group mb-2';

            div.innerHTML =
                `<input type="text"
                        name="Telefonos[${telefonoIdx}]"
                        class="form-control"
                        placeholder="88888888"
                        maxlength="20" />

                 <button type="button"
                         class="btn btn-danger btn-sm"
                         onclick="eliminarCampo(this)">
                    ×
                 </button>`;

            document.getElementById('telefonos-container').appendChild(div);
            telefonoIdx++;
        }

        function eliminarCampo(btn) {
            btn.closest('.input-group').remove();
        }
    </script>
}