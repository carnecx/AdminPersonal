@page
@model AdminPersonal.Pages.AccionesPersonal.DeleteModel
@{
    ViewData["Title"] = "Eliminar Acción de Personal";
}

<div class="container mt-4">
    <h2>Eliminar Acción de Personal</h2>
    
    <div class="alert alert-danger text-center">
        <h4>¿Realmente desea eliminar el elemento seleccionado?</h4>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <p><strong>Código:</strong> @Model.Accion.Codigo</p>
            <p><strong>Fecha:</strong> @Model.Accion.Fecha.ToString("dd/MM/yyyy")</p>
            <p><strong>Descripción:</strong> @Model.Accion.Descripcion</p>
            <p><strong>Empleado:</strong> @Model.Accion.NombreEmpleado</p>
            <p><strong>Jefatura que Aprueba:</strong> @Model.Accion.NombreJefatura</p>
        </div>
    </div>

    <form method="post" class="text-center">
        <button type="submit" class="btn btn-danger px-4">Si</button>
        <a asp-page="Index" class="btn btn-secondary px-4">No</a>
    </form>
</div>
