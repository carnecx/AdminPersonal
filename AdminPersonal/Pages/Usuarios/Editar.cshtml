@page
@model AdminPersonal.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Administración de Usuarios";
}

<!-- titulo principal de la pantalla -->
<h2 class="mb-3">Administración de Usuarios</h2>

<!-- mensaje mostrado cuando una accion se realiza correctamente -->
@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

<!-- mensaje mostrado cuando ocurre un error -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- boton para registrar un nuevo usuario -->
<a asp-page="Crear" class="btn btn-primary mb-3">
    + Nuevo Usuario
</a>

<!-- tabla que muestra los usuarios registrados -->
<table class="table table-bordered table-striped">

    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Nombre de usuario</th>
            <th>Nombre completo</th>
            <th>Correo</th>
            <th>Roles</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>

        <!-- recorre todos los usuarios obtenidos de la base de datos -->
        @foreach (var u in Model.Usuarios)
        {
            <tr>

                <!-- identificador del usuario -->
                <td>@u.IdUsuario</td>

                <!-- nombre de usuario utilizado para iniciar sesion -->
                <td>@u.NombreUsuario</td>

                <!-- nombre completo del usuario -->
                <td>@u.NombreCompleto</td>

                <!-- correo electronico -->
                <td>@u.Correo</td>

                <!-- roles asignados al usuario -->
                <td>@u.RolesNombres</td>

                <!-- muestra el estado actual del usuario -->
                <td>

                    @if (u.Estado == "Activo")
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else if (u.Estado == "Inactivo")
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Bloqueado</span>
                    }

                </td>

                <!-- botones para editar, activar, inactivar o eliminar -->
                <td>

                    <!-- boton para editar informacion -->
                    <a asp-page="Editar"
                       asp-route-id="@u.IdUsuario"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <!-- formulario para cambiar el estado -->
                    <form method="post"
                          asp-page-handler="CambiarEstado"
                          class="d-inline">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="id"
                               value="@u.IdUsuario" />

                        @if (u.Estado == "Activo")
                        {
                            <input type="hidden"
                                   name="nuevoEstado"
                                   value="Inactivo" />

                            <button type="submit"
                                    class="btn btn-secondary btn-sm">
                                Inactivar
                            </button>
                        }
                        else
                        {
                            <input type="hidden"
                                   name="nuevoEstado"
                                   value="Activo" />

                            <button type="submit"
                                    class="btn btn-primary btn-sm">
                                Activar
                            </button>
                        }

                    </form>

                    <!-- formulario para eliminar un usuario -->
                    <form method="post"
                          asp-page-handler="Eliminar"
                          class="d-inline"
                          onsubmit="return confirm('¿Está seguro de eliminar este usuario?');">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="id"
                               value="@u.IdUsuario" />

                        <button type="submit"
                                class="btn btn-danger btn-sm">
                            Eliminar
                        </button>

                    </form>

                </td>

            </tr>
        }

    </tbody>

</table>