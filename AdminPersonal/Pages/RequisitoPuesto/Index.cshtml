@page
@model AdminPersonal.Pages.RequisitoPuesto.IndexModel
@{
    ViewData["Title"] = "Requisitos del Puesto";
}

<h2>Requisitos del Puesto</h2>

@if (TempData["Mensaje"] != null || TempData["Error"] != null)
{
    <div class="modal fade" id="mensajeModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">
                        @(TempData["Error"] != null ? "Error" : "Información")
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body">
                    @(TempData["Error"] ?? TempData["Mensaje"])
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-primary"
                            data-bs-dismiss="modal">
                        Aceptar
                    </button>
                </div>

            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new bootstrap.Modal(
                document.getElementById('mensajeModal')
            ).show();
        });
    </script>
}

<br />

<a asp-page="Crear" class="btn btn-primary">
    Nuevo Requisito
</a>

<br />
<br />

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Puesto</th>
            <th>Nombre del Requisito</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Requisitos)
        {
            <tr>
                <td>@item.nombre_puesto</td>
                <td>@item.nombre_requisito</td>

                <td>
                    <a asp-page="Editar"
                       asp-route-id="@item.id_requisito"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <button type="button"
                            class="btn btn-danger btn-sm btnEliminar"
                            data-id="@item.id_requisito">
                        Eliminar
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="modal fade" id="eliminarModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    Confirmar eliminación
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                ¿Realmente desea eliminar el elemento seleccionado?
            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <form method="post"
                      asp-page="Eliminar"
                      id="formEliminar">

                    <input type="hidden"
                           id="idEliminar"
                           name="id" />

                    <button type="submit"
                            class="btn btn-danger">
                        Eliminar
                    </button>

                </form>

            </div>

        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.btnEliminar')
        .forEach(btn => {

            btn.addEventListener('click', function () {

                document.getElementById('idEliminar').value =
                    this.dataset.id;

                new bootstrap.Modal(
                    document.getElementById('eliminarModal')
                ).show();

            });

        });
</script>