@page
@model AdminPersonal.Pages.PreparacionAcademica.EditModel
@{
    ViewData["Title"] = "Editar Preparación Académica";
}

<div class="container mt-4">
    <h2>Editar Preparación Académica</h2>
    
    <form method="post">
        <input type="hidden" asp-for="Preparacion.Id" />
        <input type="hidden" asp-for="Preparacion.OferenteId" />
        
        <div class="mb-3">
            <label asp-for="Preparacion.InstitucionEducativaId" class="form-label">Institución Educativa *</label>
            <select asp-for="Preparacion.InstitucionEducativaId" class="form-control" required>
                <option value="">Seleccione una institución</option>
                @foreach (var inst in Model.InstitucionesList)
                {
                    <option value="@inst.Id">@inst.Nombre</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="Preparacion.Titulo" class="form-label">Título Obtenido *</label>
            <input asp-for="Preparacion.Titulo" class="form-control" maxlength="100" required />
        </div>

        <div class="mb-3">
            <label asp-for="Preparacion.FechaInicio" class="form-label">Fecha de Inicio *</label>
            <input asp-for="Preparacion.FechaInicio" type="date" class="form-control" required />
        </div>

        <div class="mb-3">
            <label asp-for="Preparacion.FechaFin" class="form-label">Fecha de Fin *</label>
            <input asp-for="Preparacion.FechaFin" type="date" class="form-control" required />
        </div>

        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        <a asp-page="Index" asp-route-oferenteId="@Model.Preparacion.OferenteId" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
