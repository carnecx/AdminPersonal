@page
@model AdminPersonal.Pages.Usuarios.CrearModel
@{
    ViewData["Title"] = "Crear Usuario";
}

<h2 class="mb-3">Crear Usuario</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Usuario.NombreUsuario" class="form-label">Nombre de usuario *</label>
        <input asp-for="Usuario.NombreUsuario" class="form-control" required />
    </div>

    <div class="mb-3">
        <label asp-for="Usuario.NombreCompleto" class="form-label">Nombre completo *</label>
        <input asp-for="Usuario.NombreCompleto" class="form-control" required />
    </div>

    <div class="mb-3">
        <label asp-for="Usuario.Correo" class="form-label">Correo *</label>
        <input asp-for="Usuario.Correo" type="email" class="form-control" required />
    </div>

    <div class="mb-3">
        <label asp-for="Usuario.Contrasena" class="form-label">Contraseña *</label>
        <input asp-for="Usuario.Contrasena" type="password" class="form-control" required />
    </div>

    <div class="mb-3">
        <label asp-for="Usuario.Estado" class="form-label">Estado *</label>
        <select asp-for="Usuario.Estado" class="form-control" required>
            <option value="Activo">Activo</option>
            <option value="Inactivo">Inactivo</option>
            <option value="Bloqueado">Bloqueado</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Roles * (puede seleccionar varios)</label>
        @foreach (var rol in Model.Roles)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox"
                       name="Usuario.RolesSeleccionados" value="@rol.id_rol"
                       id="rol_@rol.id_rol" />
                <label class="form-check-label" for="rol_@rol.id_rol">
                    @rol.nombre_rol
                </label>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-page="Index" class="btn btn-secondary">Volver</a>
</form>