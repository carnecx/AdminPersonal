@page
@model AdminPersonal.Pages.ExperienciaLaboral.DeleteModel
@{
    ViewData["Title"] = "Eliminar Experiencia Laboral";
}

<div class="container mt-4">
    <h2>Eliminar Experiencia Laboral</h2>
    
    <div class="alert alert-danger text-center">
        <h4>¿Realmente desea eliminar el elemento seleccionado?</h4>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <p><strong>Empresa:</strong> @Model.Experiencia.NombreEmpresa</p>
            <p><strong>Puesto:</strong> @Model.Experiencia.PuestoDesempenado</p>
            <p><strong>Fecha Inicio:</strong> @Model.Experiencia.FechaInicio.ToString("dd/MM/yyyy")</p>
            <p><strong>Fecha Fin:</strong> @Model.Experiencia.FechaFin.ToString("dd/MM/yyyy")</p>
        </div>
    </div>

    <form method="post" class="text-center">
        <button type="submit" class="btn btn-danger px-4">Si</button>
        <a asp-page="Index" asp-route-oferenteId="@Model.Experiencia.OferenteId" class="btn btn-secondary px-4">No</a>
    </form>
</div>
