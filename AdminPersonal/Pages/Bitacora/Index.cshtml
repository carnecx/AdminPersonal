@page

@model AdminPersonal.Pages.Bitacora.IndexModel

<!-- titulo principal de la pantalla -->
<h1>Bitacoras</h1>

<!-- formulario utilizado para filtrar y ordenar registros -->
<form method="get" class="row g-2 mb-3">

    <!-- filtro por nombre de usuario -->
    <div class="col-md-3">
        <input asp-for="Usuario"
               class="form-control"
               placeholder="Filtrar por usuario" />
    </div>

    <!-- filtro por descripcion -->
    <div class="col-md-4">
        <input asp-for="Descripcion"
               class="form-control"
               placeholder="Buscar en descripcion" />
    </div>

    <!-- lista de opciones para ordenar resultados -->
    <div class="col-md-3">
        <select asp-for="Orden" class="form-control">

            <!-- orden por fecha descendente -->
            <option value="fecha_desc">Fecha descendente</option>

            <!-- orden por fecha ascendente -->
            <option value="fecha_asc">Fecha ascendente</option>

            <!-- orden alfabetico por usuario -->
            <option value="usuario_asc">Usuario ascendente</option>

            <!-- orden alfabetico inverso por usuario -->
            <option value="usuario_desc">Usuario descendente</option>

        </select>
    </div>

    <!-- boton que ejecuta los filtros -->
    <div class="col-md-2">
        <button class="btn btn-primary w-100" type="submit">
            Filtrar
        </button>
    </div>

</form>

<!-- boton para regresar a la pantalla principal -->
<a class="btn btn-secondary mb-3"
   asp-page="/Home/Bienvenida">
    Volver
</a>

<!-- tabla que muestra los registros de bitacora -->
<table class="table table-bordered table-striped">

    <thead class="table-dark">
        <tr>
            <th>Fecha</th>
            <th>Usuario</th>
            <th>Descripcion</th>
        </tr>
    </thead>

    <tbody>

        <!-- recorre todos los registros obtenidos -->
        @foreach (var item in Model.Lista)
        {
            <tr>

                <!-- fecha de la accion -->
                <td>@item.fecha</td>

                <!-- usuario que realizo la accion -->
                <td>@item.nombre_usuario</td>

                <!-- descripcion de la accion -->
                <td>@item.descripcion</td>

            </tr>
        }

    </tbody>

</table>

<!-- control de paginacion -->
<nav>

    <ul class="pagination">

        <!-- boton para ir a la pagina anterior -->
        <li class="page-item @(Model.Pagina <= 1 ? "disabled" : "")">

            <a class="page-link"
               asp-page="/Bitacora/Index"
               asp-route-pagina="@(Model.Pagina - 1)"
               asp-route-usuario="@Model.Usuario"
               asp-route-descripcion="@Model.Descripcion"
               asp-route-orden="@Model.Orden">

                Anterior

            </a>

        </li>

        <!-- muestra la pagina actual y el total -->
        <li class="page-item disabled">

            <span class="page-link">
                Pagina @Model.Pagina de @Model.TotalPaginas
            </span>

        </li>

        <!-- boton para ir a la pagina siguiente -->
        <li class="page-item @(Model.Pagina >= Model.TotalPaginas ? "disabled" : "")">

            <a class="page-link"
               asp-page="/Bitacora/Index"
               asp-route-pagina="@(Model.Pagina + 1)"
               asp-route-usuario="@Model.Usuario"
               asp-route-descripcion="@Model.Descripcion"
               asp-route-orden="@Model.Orden">

                Siguiente

            </a>

        </li>

    </ul>

</nav>