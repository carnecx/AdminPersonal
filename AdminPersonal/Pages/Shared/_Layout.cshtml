<!DOCTYPE html>
<html lang="es">
<head>
    <!-- configura los caracteres del sitio -->
    <meta charset="utf-8" />

    <!-- permite que el sitio sea adaptable a diferentes tama˝os de pantalla -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- titulo que aparece en la pesta˝a del navegador -->
    <title>Administracion de Personal</title>

    <!-- referencia a bootstrap para estilos visuales -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- referencia a bootstrap icons para usar iconos en el menu -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- hoja de estilos propia del proyecto -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <!-- barra superior del sistema -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container-fluid">

            <!-- nombre del sistema e icono principal -->
            <a class="navbar-brand fw-bold" asp-page="/Home/Bienvenida">
                <i class="bi bi-people-fill me-2"></i>SM - Administracion de Personal
            </a>

            <!-- muestra datos del usuario solo si existe una sesion activa -->
            @if (Context.Session.GetInt32("IdUsuario") != null)
            {
                <div class="d-flex align-items-center">

                    <!-- avatar y nombre completo del usuario logueado -->
                    <span class="text-white me-3">
                        <i class="bi bi-person-circle me-1"></i>
                        @Context.Session.GetString("NombreCompleto")
                    </span>

                    <!-- boton para cerrar sesion -->
                    <a asp-page="/Account/Logout" class="btn btn-light btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Salir
                    </a>
                </div>
            }
        </div>
    </nav>

    <!-- contenedor principal del sitio -->
    <div class="container-fluid">
        <div class="row min-vh-100">

            <!-- si hay sesion activa, muestra menu lateral y contenido -->
            @if (Context.Session.GetInt32("IdUsuario") != null)
            {
                <!-- obtiene las pantallas permitidas segun el rol del usuario -->
                var pantallasStr = Context.Session.GetString("PantallasRol") ?? "";

                <!-- separa las pantallas guardadas en sesion y las normaliza -->
                var pantallas = pantallasStr
                .Split('|', StringSplitOptions.RemoveEmptyEntries)
                .Select(p => p.Trim().ToLower())
                .ToHashSet();

                <!-- menu lateral del sistema -->
                <aside class="col-md-2 bg-light border-end p-3">

                    <!-- titulo del menu -->
                    <h6 class="text-uppercase text-muted fw-bold mb-3">Menu</h6>

                    <!-- opcion fija de bienvenida -->
                    <a class="d-block mb-2 text-decoration-none" asp-page="/Home/Bienvenida">
                        <i class="bi bi-house-door me-2"></i>Bienvenida
                    </a>

                    <!-- opcion visible si el rol tiene permiso para compania -->
                    @if (pantallas.Contains("compania"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/Compania/Index">
                            <i class="bi bi-building me-2"></i>Compania
                        </a>
                    }

                    <!-- opcion visible si el rol tiene permiso para parametros -->
                    @if (pantallas.Contains("parametros"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/Parametro/Index">
                            <i class="bi bi-sliders me-2"></i>Parametros
                        </a>
                    }

                    <!-- opcion visible si el rol tiene permiso para roles -->
                    @if (pantallas.Contains("roles"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/Rol/Index">
                            <i class="bi bi-person-badge me-2"></i>Roles
                        </a>
                    }

                    <!-- opcion visible si el rol tiene permiso para usuarios -->
                    @if (pantallas.Contains("usuarios"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/Usuarios/Index">
                            <i class="bi bi-person-gear me-2"></i>Usuarios
                        </a>
                    }

                    <!-- opcion visible si el rol tiene permiso para pantallas -->
                    @if (pantallas.Contains("pantallas"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/Pantalla/Index">
                            <i class="bi bi-display me-2"></i>Pantallas
                        </a>
                    }

                    <!-- opcion visible si el rol tiene permiso para requisitos de puesto -->
                    @if (pantallas.Contains("requisitos de puesto"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/RequisitoPuesto/Index">
                            <i class="bi bi-clipboard-check me-2"></i>Requisitos de Puesto
                        </a>
                    }

                    <!-- opcion visible si el rol tiene permiso para instituciones -->
                    @if (pantallas.Contains("instituciones"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/Instituciones/Index">
                            <i class="bi bi-mortarboard me-2"></i>Instituciones
                        </a>
                    }

                    <!-- opcion visible si el rol tiene permiso para cargar ubicaciones -->
                    @if (pantallas.Contains("cargar ubicaciones"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/Ubicaciones/Cargar">
                            <i class="bi bi-upload me-2"></i>Cargar ubicaciones
                        </a>
                    }

                    <!-- opcion visible si el rol tiene permiso para oferentes -->
                    @if (pantallas.Contains("oferentes"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/Oferentes/Index">
                            <i class="bi bi-person-lines-fill me-2"></i>Oferentes
                        </a>
                    }

                    <!-- opcion visible si el rol tiene permiso para concursos -->
                    @if (pantallas.Contains("concursos"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/Concursos/Index">
                            <i class="bi bi-trophy me-2"></i>Concursos
                        </a>
                    }

                    <!-- opcion visible si el rol tiene permiso para areas -->
                    @if (pantallas.Contains("areas"))
                    {
                        <a class="d-block mb-2 text-decoration-none" href="/Areas">
                            <i class="bi bi-diagram-3 me-2"></i>┴reas
                        </a>
                    }

                    <!-- opcion para contratar empleado -->
                    <a class="d-block mb-2 text-decoration-none" asp-page="/Empleados/ContratarEmpleado">
                        <i class="bi bi-person-plus me-2"></i>Contratar empleado
                    </a>

                    <!-- opcion visible si el rol tiene permiso para bitacora -->
                    @if (pantallas.Contains("bitacora"))
                    {
                        <a class="d-block mb-2 text-decoration-none" asp-page="/Bitacora/Index">
                            <i class="bi bi-journal-text me-2"></i>Bitacora
                        </a>
                    }
                </aside>

                <!-- aqui se renderiza el contenido de cada pagina -->
                <main class="col-md-10 p-4">@RenderBody()</main>
            }
            else
            {
                <!-- si no hay sesion, muestra solo el contenido sin menu lateral -->
                <main class="col-md-12 p-4">@RenderBody()</main>
            }
        </div>
    </div>

    <!-- scripts de bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- permite cargar scripts particulares de cada pagina -->
    @await RenderSectionAsync("Scripts", required: false)

    <!-- temporizador visual para cerrar sesion despues de 5 minutos -->
    @if (Context.Session.GetInt32("IdUsuario") != null)
    {
        <script>
            // tiempo de sesion en milisegundos
            let tiempoSesion = 5 * 60 * 1000;

            // al cumplirse el tiempo, redirige al logout con mensaje de sesion expirada
            setTimeout(function () {
                window.location.href = '/Account/Logout?mensaje=La sesion ha expirado.';
            }, tiempoSesion);
        </script>
    }
</body>
</html>