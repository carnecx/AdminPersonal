@page
@model AdminPersonal.Pages.Entrevistas.EditModel
@{
    ViewData["Title"] = "Editar Entrevista";
}

<div class="container mt-4">
    <h2>Editar Entrevista</h2>
    
    <form method="post">
        <input type="hidden" asp-for="Entrevista.Id" />
        <input type="hidden" asp-for="Entrevista.OferenteId" />
        
        <div class="mb-3">
            <label class="form-label">Oferente</label>
            <input type="text" class="form-control" value="@Model.Entrevista.NombreOferente" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">Entrevistador</label>
            <select asp-for="Entrevista.EmpleadoEntrevistadorId" class="form-control" required>
                @foreach (var emp in Model.EmpleadosList)
                {
                    <option value="@emp.Id">@emp.Nombre</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Fecha y Hora</label>
            <input asp-for="Entrevista.FechaEntrevista" type="datetime-local" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Estado</label>
            <select asp-for="Entrevista.Estado" class="form-control">
                <option value="Pendiente">Pendiente</option>
                <option value="Realizada">Realizada</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
