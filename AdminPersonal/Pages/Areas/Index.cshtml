@page
@model AdminPersonal.Pages.Areas.IndexModel
@{
    ViewData["Title"] = "Administración de Áreas";
}

<h2>Administración de Áreas</h2>

@if (!string.IsNullOrEmpty(Model.MensajeExito))
{
    <div class="alert alert-success">@Model.MensajeExito</div>
}
@if (!string.IsNullOrEmpty(Model.MensajeError))
{
    <div class="alert alert-danger">@Model.MensajeError</div>
}

<a href="/Areas/Crear" class="btn btn-primary mb-3">Nuevo</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Código</th>
            <th>Nombre</th>
            <th>Jefatura</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var area in Model.Areas)
        {
            <tr>
                <td>@area.IdArea</td>
                <td>@area.Codigo</td>
                <td>@area.Nombre</td>
                <td>@area.NombreJefatura</td>
                <td>
                    <a href="/Areas/Editar?id=@area.IdArea" class="btn btn-warning btn-sm">Editar</a>
                    <a href="/Areas/Eliminar?id=@area.IdArea" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>