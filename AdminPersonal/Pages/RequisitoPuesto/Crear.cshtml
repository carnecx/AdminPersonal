@page
@model AdminPersonal.Pages.RequisitoPuesto.CrearModel
@{
    ViewData["Title"] = "Nuevo Requisito";
}

<h2>Nuevo Requisito</h2>

@if (ViewData["Error"] != null)
{
    <div class="alert alert-danger">@ViewData["Error"]</div>
}

<br />

<form method="post">
    <div class="mb-3">
        <label>Puesto</label>
        <select name="Requisito.id_puesto" class="form-control" required>
            <option value="">-- Seleccione un puesto --</option>
            @foreach (var puesto in Model.Puestos)
            {
                <option value="@puesto.id_puesto">@puesto.nombre</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Nombre del Requisito</label>
        <input type="text" name="Requisito.nombre_requisito" class="form-control" maxlength="200" value="@Model.Requisito.nombre_requisito" required />
    </div>

    <br />
    <a asp-page="Index" class="btn btn-secondary">Volver</a>
    <button type="submit" class="btn btn-primary">Guardar</button>
</form>
