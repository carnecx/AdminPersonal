@page
@model AdminPersonal.Pages.ExperienciaLaboral.EditModel
@{
    ViewData["Title"] = "Editar Experiencia Laboral";
}

<div class="container mt-4">
    <h2>Editar Experiencia Laboral</h2>
    
    <form method="post">
        <input type="hidden" asp-for="Experiencia.Id" />
        <input type="hidden" asp-for="Experiencia.OferenteId" />
        
        <div class="mb-3">
            <label asp-for="Experiencia.NombreEmpresa" class="form-label">Nombre de la Empresa *</label>
            <input asp-for="Experiencia.NombreEmpresa" class="form-control" maxlength="100" required />
        </div>

        <div class="mb-3">
            <label asp-for="Experiencia.PuestoDesempenado" class="form-label">Puesto Desempeñado *</label>
            <input asp-for="Experiencia.PuestoDesempenado" class="form-control" maxlength="100" required />
        </div>

        <div class="mb-3">
            <label asp-for="Experiencia.FechaInicio" class="form-label">Fecha de Inicio *</label>
            <input asp-for="Experiencia.FechaInicio" type="date" class="form-control" required />
        </div>

        <div class="mb-3">
            <label asp-for="Experiencia.FechaFin" class="form-label">Fecha de Fin *</label>
            <input asp-for="Experiencia.FechaFin" type="date" class="form-control" required />
        </div>

        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        <a asp-page="Index" asp-route-oferenteId="@Model.Experiencia.OferenteId" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
