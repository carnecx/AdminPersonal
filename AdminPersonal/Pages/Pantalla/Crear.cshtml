@page
@model AdminPersonal.Pages.Pantalla.CrearModel
@using AdminPersonal.Entities

@{
    ViewData["Title"] = "Nueva Pantalla";
}

<h2>Nueva Pantalla</h2>

@if (ViewData["Error"] != null)
{
    <div class="alert alert-danger">@ViewData["Error"]</div>
}

<br />
<form method="post">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label>Nombre de la Pantalla</label>
        <input type="text" name="Pantalla.nombre_pantalla" class="form-control"
               maxlength="100" value="@Model.Pantalla.nombre_pantalla" required />
    </div>
    <div class="mb-3">
        <label>Roles que pueden ver esta pantalla</label>
        <div class="border rounded p-3">
            @foreach (var rol in Model.Roles)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox"
                           name="RolesSeleccionados" value="@rol.id_rol"
                           id="rol_@rol.id_rol" />
                    <label class="form-check-label" for="rol_@rol.id_rol">
                        @rol.nombre_rol
                    </label>
                </div>
            }
        </div>
    </div>
    <br />
    <a asp-page="Index" class="btn btn-secondary">Volver</a>
    <button type="submit" class="btn btn-primary">Guardar</button>
</form>
