@page
@model AdminPersonal.Pages.Oferentes.CrearModel
@{
    ViewData["Title"] = "Nuevo Oferente";
}

<h2>Nuevo Oferente</h2>

@if (ViewData["Error"] != null)
{
    <div class="alert alert-danger">@ViewData["Error"]</div>
}

<form method="post">

    <div class="mb-3">
        <label>Tipo de Identificación</label>
        <select name="Oferente.TipoIdentificacion" class="form-control" required>
            <option value="">-- Seleccione --</option>
            <option value="Cédula de identidad">Cédula de identidad</option>
            <option value="DIMEX">DIMEX</option>
            <option value="Pasaporte">Pasaporte</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Identificación</label>
        <input type="text" name="Oferente.Identificacion" class="form-control" maxlength="20" required />
    </div>

    <div class="mb-3">
        <label>Nombre Completo</label>
        <input type="text" name="Oferente.NombreCompleto" class="form-control" maxlength="150" required />
    </div>

    <div class="mb-3">
        <label>Fecha de Nacimiento</label>
        <input type="date" name="Oferente.FechaNacimiento" class="form-control" required />
    </div>

    <hr />
    <h5>Correos Electrónicos <small class="text-muted">(al menos uno)</small></h5>
    <div id="correos-container">
        <div class="input-group mb-2">
            <input type="email" name="Correos[0]" class="form-control" placeholder="correo@ejemplo.com" />
            <button type="button" class="btn btn-danger btn-sm" onclick="eliminarCampo(this)">×</button>
        </div>
    </div>
    <button type="button" class="btn btn-secondary btn-sm mb-3" onclick="agregarCorreo()">+ Agregar correo</button>

    <hr />
    <h5>Teléfonos <small class="text-muted">(al menos uno)</small></h5>
    <div id="telefonos-container">
        <div class="input-group mb-2">
            <input type="text" name="Telefonos[0]" class="form-control" placeholder="88888888" maxlength="20" />
            <button type="button" class="btn btn-danger btn-sm" onclick="eliminarCampo(this)">×</button>
        </div>
    </div>
    <button type="button" class="btn btn-secondary btn-sm mb-3" onclick="agregarTelefono()">+ Agregar teléfono</button>

    <hr />
    <h5>Concursos</h5>
    <div class="mb-3">
        @foreach (var c in Model.Concursos)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="ConcursosSeleccionados"
                       value="@c.id_concurso" id="conc_@c.id_concurso" />
                <label class="form-check-label" for="conc_@c.id_concurso">
                    @c.Nombre (@c.Codigo)
                </label>
            </div>
        }
    </div>

    <br />
    <a asp-page="Index" class="btn btn-secondary">Volver</a>
    <button type="submit" class="btn btn-primary">Guardar</button>
</form>

@section Scripts {
    <script>
        let correoIdx = 1;
        let telefonoIdx = 1;

        function agregarCorreo() {
            const div = document.createElement('div');
            div.className = 'input-group mb-2';
            div.innerHTML = `<input type="email" name="Correos[${correoIdx}]" class="form-control" placeholder="correo@ejemplo.com" />
                             <button type="button" class="btn btn-danger btn-sm" onclick="eliminarCampo(this)">×</button>`;
            document.getElementById('correos-container').appendChild(div);
            correoIdx++;
        }

        function agregarTelefono() {
            const div = document.createElement('div');
            div.className = 'input-group mb-2';
            div.innerHTML = `<input type="text" name="Telefonos[${telefonoIdx}]" class="form-control" placeholder="88888888" maxlength="20" />
                             <button type="button" class="btn btn-danger btn-sm" onclick="eliminarCampo(this)">×</button>`;
            document.getElementById('telefonos-container').appendChild(div);
            telefonoIdx++;
        }

        function eliminarCampo(btn) {
            btn.closest('.input-group').remove();
        }
    </script>
}