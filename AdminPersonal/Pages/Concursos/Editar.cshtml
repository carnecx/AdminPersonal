@page "{id:int}"
@model AdminPersonal.Pages.Concursos.EditarModel
@{
    ViewData["Title"] = "Editar Concurso";
}

<h2>Editar Concurso</h2>

@if (ViewData["Error"] != null)
{
    <div class="alert alert-danger">@ViewData["Error"]</div>
}

<form method="post">
    <input type="hidden" name="Concurso.id_concurso" value="@Model.Concurso.id_concurso" />

    <div class="mb-3">
        <label>Código</label>
        <input type="text" name="Concurso.Codigo" class="form-control" maxlength="50"
               value="@Model.Concurso.Codigo" required />
    </div>
    <div class="mb-3">
        <label>Nombre</label>
        <input type="text" name="Concurso.Nombre" class="form-control" maxlength="150"
               value="@Model.Concurso.Nombre" required />
    </div>
    <div class="mb-3">
        <label>Fecha de Inicio</label>
        <input type="date" name="Concurso.FechaInicio" class="form-control"
               value="@Model.Concurso.FechaInicio.ToString("yyyy-MM-dd")" required />
    </div>
    <div class="mb-3">
        <label>Fecha de Fin</label>
        <input type="date" name="Concurso.FechaFin" class="form-control"
               value="@Model.Concurso.FechaFin.ToString("yyyy-MM-dd")" required />
    </div>
    <br />
    <a asp-page="Index" class="btn btn-secondary">Volver</a>
    <button type="submit" class="btn btn-primary">Guardar</button>
</form>