@page
@model AdminPersonal.Pages.AccionesPersonal.IndexModel
@{
    ViewData["Title"] = "Acciones de Personal";
}

<div class="container mt-4">
    <h2>Acciones de Personal</h2>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    <a asp-page="Create" class="btn btn-primary mb-3">+ Nueva Acción</a>
    
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Código</th>
                <th>Fecha</th>
                <th>Descripción</th>
                <th>Empleado</th>
                <th>Jefatura que Aprueba</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var accion in Model.AccionesList)
            {
                <tr>
                    <td>@accion.Codigo</td>
                    <td>@accion.Fecha.ToString("dd/MM/yyyy")</td>
                    <td>@accion.Descripcion</td>
                    <td>@accion.NombreEmpleado</td>
                    <td>@accion.NombreJefatura</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@accion.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-page="Delete" asp-route-id="@accion.Id" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Navegación de páginas">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-p="@(Model.PageIndex - 1)">Anterior</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.PageIndex == i ? "active" : "")">
                        <a class="page-link" asp-page="Index" asp-route-p="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-p="@(Model.PageIndex + 1)">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
</div>
