<!-- titulo de la pantalla -->
<h1>Usuarios</h1>

<!-- muestra mensajes de exito -->
@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

<!-- boton para crear un nuevo usuario -->
<a class="btn btn-primary" asp-page="Crear">
    Nuevo usuario
</a>

<!-- tabla que muestra los usuarios registrados -->
<table class="table table-bordered">

    <thead>
        <tr>
            <th>Usuario</th>
            <th>Nombre</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>

        <!-- recorre la lista de usuarios -->
        @foreach (var item in Model.Usuarios)
        {
            <tr>

                <!-- nombre de usuario -->
                <td>@item.NombreUsuario</td>

                <!-- nombre completo -->
                <td>@item.NombreCompleto</td>

                <!-- estado actual -->
                <td>@item.Estado</td>

                <!-- botones de accion -->
                <td>
                    <a asp-page="Editar"
                       asp-route-id="@item.IdUsuario">
                        Editar
                    </a>
                </td>

            </tr>
        }

    </tbody>

</table>