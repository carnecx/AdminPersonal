@page
@model AdminPersonal.Pages.Entrevistas.CreateModel
@{
    ViewData["Title"] = "Nueva Entrevista";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">📅 Agendar Nueva Entrevista</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Oferente *</label>
                            <select asp-for="Entrevista.OferenteId" class="form-select" required>
                                <option value="">-- Seleccione un oferente --</option>
                                @foreach (var of in Model.OferentesList)
                                {
                                    <option value="@of.Id">@of.Nombre</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Entrevistador *</label>
                            <select asp-for="Entrevista.EmpleadoEntrevistadorId" class="form-select" required>
                                <option value="">-- Seleccione un empleado --</option>
                                @foreach (var emp in Model.EmpleadosList)
                                {
                                    <option value="@emp.Id">@emp.Nombre</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Fecha y Hora *</label>
                            <input asp-for="Entrevista.FechaEntrevista" type="datetime-local" class="form-control" required />
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-success">💾 Guardar</button>
                            <a asp-page="Index" class="btn btn-secondary">🔙 Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
