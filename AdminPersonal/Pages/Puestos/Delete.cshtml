@page
@model AdminPersonal.Pages.Puestos.DeleteModel
@{
    ViewData["Title"] = "Eliminar Puesto";
}

<div class="container mt-4">
    <h2>Eliminar Puesto</h2>
    
    <div class="alert alert-danger text-center">
        <h4>¿Realmente desea eliminar el elemento seleccionado?</h4>
    </div>

    <div asp-validation-summary="ModelOnly" class="alert alert-warning text-center fw-bold"></div>

    <div class="card mb-3">
        <div class="card-body">
            <p><strong>Código:</strong> @Model.Puesto.Codigo</p>
            <p><strong>Nombre:</strong> @Model.Puesto.Nombre</p>
            <p><strong>Salario:</strong> @Model.Puesto.Salario.ToString("C")</p>
            <p><strong>Jefatura:</strong> @Model.Puesto.NombreJefatura</p>
        </div>
    </div>

    <form method="post" class="text-center">
        <button type="submit" class="btn btn-danger px-4">Si</button>
        <a asp-page="Index" class="btn btn-secondary px-4">No</a>
    </form>
</div>
