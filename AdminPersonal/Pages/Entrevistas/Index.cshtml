@page
@model AdminPersonal.Pages.Entrevistas.IndexModel
@{
    ViewData["Title"] = "Agendar Entrevistas";
}

<div class="container mt-4">
    <h2>📅 Agendar Entrevistas</h2>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            ✅ @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    <a asp-page="Create" class="btn btn-primary mb-3">
        + Agendar Nueva Entrevista
    </a>
    
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th style="width: 25%">Oferente</th>
                <th style="width: 25%">Entrevistador</th>
                <th style="width: 25%">Fecha y Hora</th>
                <th style="width: 10%">Estado</th>
                <th style="width: 15%">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.EntrevistasList)
            {
                <tr>
                    <td>@item.NombreOferente</td>
                    <td>@item.NombreEntrevistador</td>
                    <td>@item.FechaEntrevista.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-center">
                        @if (item.Estado == "Pendiente")
                        {
                            <span class="badge bg-warning text-dark" style="padding: 5px 10px;">⏳ Pendiente</span>
                        }
                        else
                        {
                            <span class="badge bg-success" style="padding: 5px 10px;">✅ Realizada</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">✏️ Editar</a>
                        <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger me-1">🗑️ Eliminar</a>
                        @if (item.Estado == "Pendiente")
                        {
                            <a asp-page="Index" asp-page-handler="Completar" asp-route-id="@item.Id" class="btn btn-sm btn-info">✅ Completar</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Navegación de páginas">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-p="@(Model.PageIndex - 1)">Anterior</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.PageIndex == i ? "active" : "")">
                        <a class="page-link" asp-page="Index" asp-route-p="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-p="@(Model.PageIndex + 1)">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
    
    @if (!Model.EntrevistasList.Any())
    {
        <div class="alert alert-info text-center">
            No hay entrevistas agendadas. Haga clic en "+ Agendar Nueva Entrevista" para crear una.
        </div>
    }
</div>
