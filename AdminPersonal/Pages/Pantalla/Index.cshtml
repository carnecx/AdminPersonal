@page
@model AdminPersonal.Pages.Pantalla.IndexModel
@{
    ViewData["Title"] = "Pantallas del sistema";
}

<h2>Pantallas del sistema</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<br />
<a asp-page="Crear" class="btn btn-primary">Nueva Pantalla</a>
<br />
<br />

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Nombre de la Pantalla</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Pantallas)
        {
            <tr>
                <td>@item.id_pantalla</td>
                <td>@item.nombre_pantalla</td>
                <td>
                    <a asp-page="Editar" asp-route-id="@item.id_pantalla" class="btn btn-warning btn-sm">Editar</a>
                    <form asp-page="Eliminar" asp-route-id="@item.id_pantalla" method="post" class="d-inline"
                          onsubmit="return confirm('¿Realmente desea eliminar el elemento seleccionado?')">
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
