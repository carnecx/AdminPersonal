@page
@model AdminPersonal.Pages.ExperienciaLaboral.IndexModel
@{
    ViewData["Title"] = "Experiencia Laboral";
}

<div class="container mt-4">
    <h2>Experiencia Laboral</h2>
    <h5>Oferente: @Model.NombreOferente</h5>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    <input type="hidden" asp-for="OferenteId" />
    
    <a asp-page="Create" asp-route-oferenteId="@Model.OferenteId" class="btn btn-primary mb-3">
        + Nueva Experiencia Laboral
    </a>
    
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Empresa</th>
                <th>Puesto</th>
                <th>Fecha Inicio</th>
                <th>Fecha Fin</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.ExperienciasList)
            {
                <tr>
                    <td>@item.NombreEmpresa</td>
                    <td>@item.PuestoDesempenado</td>
                    <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                    <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@item.Id" asp-route-oferenteId="@Model.OferenteId" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-page="Delete" asp-route-id="@item.Id" asp-route-oferenteId="@Model.OferenteId" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Navegación de páginas">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-oferenteId="@Model.OferenteId" asp-route-p="@(Model.PageIndex - 1)">Anterior</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.PageIndex == i ? "active" : "")">
                        <a class="page-link" asp-page="Index" asp-route-oferenteId="@Model.OferenteId" asp-route-p="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-oferenteId="@Model.OferenteId" asp-route-p="@(Model.PageIndex + 1)">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
    
    <a asp-page="/Index" class="btn btn-secondary">Volver al Inicio</a>
</div>
