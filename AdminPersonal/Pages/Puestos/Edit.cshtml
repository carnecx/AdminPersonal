@page
@model AdminPersonal.Pages.Puestos.EditModel
@{
    ViewData["Title"] = "Editar Puesto";
}

<div class="container mt-4">
    <h2>Editar Puesto</h2>
    
    <form method="post">
        <input type="hidden" asp-for="Puesto.Id" />
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        
        <div class="mb-3">
            <label asp-for="Puesto.Codigo" class="form-label">Código del Puesto *</label>
            <input asp-for="Puesto.Codigo" class="form-control" required />
        </div>

        <div class="mb-3">
            <label asp-for="Puesto.Nombre" class="form-label">Nombre del Puesto *</label>
            <input asp-for="Puesto.Nombre" class="form-control" required />
        </div>

        <div class="mb-3">
            <label asp-for="Puesto.Salario" class="form-label">Salario *</label>
            <input asp-for="Puesto.Salario" type="number" step="0.01" class="form-control" required />
        </div>

        <div class="mb-3">
            <label asp-for="Puesto.JefaturaPuestoId" class="form-label">ID Jefatura (opcional)</label>
            <input asp-for="Puesto.JefaturaPuestoId" type="number" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Puesto.NombreJefatura" class="form-label">Nombre Jefatura (opcional)</label>
            <input asp-for="Puesto.NombreJefatura" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
