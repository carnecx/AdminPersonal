@page

@model AdminPersonal.Pages.Ubicaciones.CargarModel

<h1>Cargar datos de ubicacion</h1>

<p>Formato del archivo CSV: provincia, canton, distrito</p>

@if (!string.IsNullOrEmpty(Model.Mensaje) || !string.IsNullOrEmpty(Model.Error))
{
    <div class="modal fade show" style="display:block;" tabindex="-1">
       
        <div class="modal-dialog">

            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">
                        @(!string.IsNullOrEmpty(Model.Error) ? "Error" : "Mensaje")
                    </h5>
                </div>

                <div class="modal-body">
                    <p>
                        @(!string.IsNullOrEmpty(Model.Error)
                                            ? Model.Error
                                            : Model.Mensaje)
                </p>
            </div>

            <div class="modal-footer">
                <a class="btn btn-primary"
                   asp-page="/Ubicaciones/Cargar">
                    Aceptar
                </a>
            </div>

        </div>

    </div>

</div>

<div class="modal-backdrop fade show"></div>


}

<form method="post" enctype="multipart/form-data">

    
    <div class="mb-3">
        <label class="form-label">Archivo CSV</label>

        <input asp-for="Datos.Archivo"
               type="file"
               class="form-control" />
    </div>

    <button class="btn btn-primary" type="submit">
        Guardar
    </button>

    <a class="btn btn-secondary"
       asp-page="/Home/Bienvenida">
        Volver
    </a>


</form>
