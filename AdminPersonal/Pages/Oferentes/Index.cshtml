@page
@model AdminPersonal.Pages.Oferentes.IndexModel
@{
    ViewData["Title"] = "Oferentes";
}

<h2>Lista de Oferentes</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<br />
<a asp-page="Crear" class="btn btn-primary">Nuevo Oferente</a>
<br />
<br />

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Identificación</th>
            <th>Tipo</th>
            <th>Nombre Completo</th>
            <th>Fecha Nacimiento</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Oferentes)
        {
            <tr>
                <td>@item.Identificacion</td>
                <td>@item.TipoIdentificacion</td>
                <td>@item.NombreCompleto</td>
                <td>@item.FechaNacimiento.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-page="Editar" asp-route-id="@item.id_oferente" class="btn btn-warning btn-sm">Editar</a>
                    <form asp-page="Eliminar" asp-route-id="@item.id_oferente" method="post" class="d-inline"
                          onsubmit="return confirm('¿Realmente desea eliminar el elemento seleccionado?')">
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>