@page
@model AdminPersonal.Pages.Compania.IndexModel
@{
    ViewData["Title"] = "Compañías";
}

<h2>Lista de Compañías</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<br />
<a asp-page="Crear" class="btn btn-primary">Nueva Compañía</a>
<br />
<br />

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Companias)
        {
            <tr>
                <td>@item.Codigo</td>
                <td>@item.Nombre</td>
                <td>
                    <a asp-page="Editar" asp-route-id="@item.id_compania" class="btn btn-warning btn-sm">Editar</a>
                    <form asp-page="Eliminar" asp-route-id="@item.id_compania" method="post" class="d-inline"
                          onsubmit="return confirm('¿Realmente desea eliminar el elemento seleccionado?')">
                          <button type="submit" class="btn btn-danger btn-sm">Eliminar</button></form>
                </td>
            </tr>
        }
    </tbody>
</table>