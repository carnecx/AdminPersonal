@page "{id:int}"
@model AdminPersonal.Pages.Pantalla.EditarModel
@using AdminPersonal.Entities

@{
    ViewData["Title"] = "Editar Pantalla";
}

<h2>Editar Pantalla</h2>

<br />

<form method="post">
    @Html.AntiForgeryToken()

    <input type="hidden"
           name="Pantalla.id_pantalla"
           value="@Model.Pantalla.id_pantalla" />

    <div class="mb-3">
        <label>Nombre de la Pantalla</label>
        <input type="text"
               name="Pantalla.nombre_pantalla"
               class="form-control"
               maxlength="100"
               value="@Model.Pantalla.nombre_pantalla"
               required />
    </div>

    <div class="mb-3">
        <label>Roles que pueden ver esta pantalla</label>

        <div class="border rounded p-3">
            @foreach (var rol in Model.Roles)
            {
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           name="RolesSeleccionados"
                           value="@rol.id_rol"
                           id="rol_@rol.id_rol"
                           @(rol.Seleccionado ? "checked" : "") />

                    <label class="form-check-label"
                           for="rol_@rol.id_rol">
                        @rol.nombre_rol
                    </label>
                </div>
            }
        </div>
    </div>

    <br />

    <a asp-page="Index"
       class="btn btn-secondary">
        Volver
    </a>

    <button type="submit"
            class="btn btn-primary">
        Guardar
    </button>
</form>

@if (ViewData["Error"] != null)
{
    <div class="modal fade" id="errorModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Error</h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body">
                    @ViewData["Error"]
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-primary"
                            data-bs-dismiss="modal">
                        Aceptar
                    </button>
                </div>

            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new bootstrap.Modal(
                document.getElementById('errorModal')
            ).show();
        });
    </script>
}