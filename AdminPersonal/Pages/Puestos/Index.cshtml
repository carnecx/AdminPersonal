@page
@model AdminPersonal.Pages.Puestos.IndexModel
@{
    ViewData["Title"] = "Administración de Puestos";
}

<div class="container mt-4">
    <h2>Administración de Puestos</h2>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    <a asp-page="Create" class="btn btn-primary mb-3">+ Nuevo Puesto</a>
    
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr><th>Código</th><th>Nombre</th><th>Salario</th><th>Jefatura</th><th>Acciones</th></tr>
        </thead>
        <tbody>
            @foreach (var puesto in Model.PuestosList)
            {
                <tr>
                    <td>@puesto.Codigo</td>
                    <td>@puesto.Nombre</td>
                    <td>@puesto.Salario.ToString("C")</td>
                    <td>@puesto.NombreJefatura</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@puesto.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-page="Delete" asp-route-id="@puesto.Id" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Navegación de páginas">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-p="@(Model.PageIndex - 1)">Anterior</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.PageIndex == i ? "active" : "")">
                        <a class="page-link" asp-page="Index" asp-route-p="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="Index" asp-route-p="@(Model.PageIndex + 1)">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
</div>
